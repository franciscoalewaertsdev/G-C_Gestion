generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum DiscountType {
  NONE
  PERCENTAGE
  FIXED
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  email        String?      @unique
  passwordHash String
  fullName     String
  active       Boolean      @default(true)
  roleId       String
  role         Role         @relation(fields: [roleId], references: [id])
  sales        Sale[]
  stockEntries StockEntry[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Supplier {
  id           String       @id @default(cuid())
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  products     Product[]
  stockEntries StockEntry[]
  monthlyPayments SupplierMonthlyPayment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([name, email])
}

model SupplierMonthlyPayment {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  year       Int
  month      Int
  isPaid     Boolean  @default(false)
  paidAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([supplierId, year, month])
  @@index([year, month])
}

model Product {
  id              String          @id @default(cuid())
  name            String
  description     String?
  barcode         String?         @unique
  costPrice       Decimal         @default(0) @db.Decimal(12, 2)
  price           Decimal         @db.Decimal(12, 2)
  currentStock    Int             @default(0)
  lowStockAlert   Int             @default(5)
  supplierId      String
  supplier        Supplier        @relation(fields: [supplierId], references: [id])
  variants        ProductVariant[]
  stockEntryItems StockEntryItem[]
  saleItems       SaleItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([name])
  @@index([barcode])
  @@index([createdAt])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  value      String
  stock      Int      @default(0)
  extraPrice Decimal? @db.Decimal(12, 2)
  saleItems  SaleItem[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
}

model StockEntry {
  id         String           @id @default(cuid())
  entryDate  DateTime         @default(now())
  supplierId String
  supplier   Supplier         @relation(fields: [supplierId], references: [id])
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  items      StockEntryItem[]
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([entryDate])
}

model StockEntryItem {
  id           String     @id @default(cuid())
  stockEntryId String
  stockEntry   StockEntry @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Int
  unitCost     Decimal?   @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())

  @@index([stockEntryId])
  @@index([productId])
}

model Customer {
  id           String    @id @default(cuid())
  name         String
  documentId   String
  email        String?
  sales        Sale[]
  invoices     Invoice[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([documentId])
}

model Sale {
  id             String       @id @default(cuid())
  saleDate       DateTime     @default(now())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  items          SaleItem[]
  invoice        Invoice?
  subtotal       Decimal      @db.Decimal(12, 2)
  discountType   DiscountType @default(NONE)
  paymentMethod  PaymentMethod @default(EFECTIVO)
  discountValue  Decimal      @default(0) @db.Decimal(12, 2)
  discountAmount Decimal      @default(0) @db.Decimal(12, 2)
  totalFinal     Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([saleDate])
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  subtotal   Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  @@index([saleId])
  @@index([productId])
  @@index([variantId])
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  saleId        String   @unique
  sale          Sale     @relation(fields: [saleId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([invoiceNumber])
  @@index([issuedAt])
}
