{
  "name": "sistema-gestion-gc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev --turbo",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev --schema ./prisma/schema.prisma",
    "prisma:migrate:deploy": "node ./node_modules/prisma/build/index.js migrate deploy --schema ./prisma/schema.prisma",
    "prisma:push": "node ./node_modules/prisma/build/index.js db push --schema ./prisma/schema.prisma",
    "prisma:studio": "node ./node_modules/prisma/build/index.js studio --schema ./prisma/schema.prisma",
    "seed": "node ./prisma/seed.js",
    "user:update": "node ./scripts/update-user-credentials.js",
    "local:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.20.0",
    "@react-pdf/renderer": "^4.1.6",
    "@tanstack/react-table": "^8.20.5",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "iconv-lite": "^0.6.3",
    "lucide-react": "^0.441.0",
    "next": "^14.2.15",
    "next-auth": "^4.24.7",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.5",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "postcss": "^8.4.47",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.13",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
